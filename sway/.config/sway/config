exec dbus-update-activation-environment --systemd DBUS_SESSION_BUS_ADDRESS DISPLAY XAUTHORITY &

exec_always "pkill kanshi; kanshi"

set $laptop_output eDP-1

output $laptop_output bg ~/Pictures/wallpaper/wallpaper.png fill
output DP-5 bg ~/Pictures/wallpaper/wallpaper.png fill

gaps inner 7px

set $mod Mod4

# Workspace names
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Switch to next/previous workspace
bindsym $mod+Next workspace next
bindsym $mod+Prior workspace prev

set $up l
set $down k
set $left j
set $right semicolon

bindsym $mod+Shift+c reload
bindsym $mod+Shift+space floating toggle

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+v split v
bindsym $mod+h split h

bindsym $mod+d exec --no-startup-id i3-dmenu-desktop --dmenu="dmenu -i -l 10 -fn "\"CaskaydiaCove\"-16" -bw 3"
bindsym $mod+Shift+q kill

bindsym $mod+Escape exec "case $(echo 'Power\nSleep\nRestart' | dmenu -i -l 10 -fn '\"CaskaydiaCove\"-16' -bw 3) in Power) systemctl poweroff ;; Sleep) systemctl suspend ;; Restart) systemctl reboot ;; esac"

bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

bindsym $mod+f fullscreen toggle

bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+x layout default

bindsym XF86MonBrightnessDown exec brightnessctl set 5%- && notify-send -t 1000 "$(brightnessctl -m | cut -d, -f4)"
bindsym XF86MonBrightnessUp exec brightnessctl set 5%+ && notify-send -t 1000 "$(brightnessctl -m | cut -d, -f4)"

bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5% && notify-send -t 1000 "Volume: $(pactl get-sink-volume @DEFAULT_SINK@ | awk '{print $5}')"
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5% && notify-send -t 1000 "Volume: $(pactl get-sink-volume @DEFAULT_SINK@ | awk '{print $5}')"
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle && notify-send -t 1000 "Volume: $(pactl get-sink-volume @DEFAULT_SINK@ | awk '{print $5}') (Muted: $(pactl get-sink-mute @DEFAULT_SINK@ | awk '{print $2}'))"
bindsym XF86AudioPlay exec playerctl play-pause && notify-send -t 1000 "Media: $(playerctl status)"

# resize window (you can also use the mouse for that)
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym $left       resize shrink width 10 px or 10 ppt
        bindsym $down       resize grow height 10 px or 10 ppt
        bindsym $up         resize shrink height 10 px or 10 ppt
        bindsym $right      resize grow width 10 px or 10 ppt

        # same bindings, but for the arrow keys
        bindsym Left        resize shrink width 10 px or 10 ppt
        bindsym Down        resize grow height 10 px or 10 ppt
        bindsym Up          resize shrink height 10 px or 10 ppt
        bindsym Right       resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or Mod1+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym Mod1+r mode "default"
}

# Tablet mode: gyroscope-based autorotation on the internal display.
mode "tablet" {
        bindsym Escape exec --no-startup-id ~/.dotfiles/scripts/.scripts/sway_tablet_autorotate stop; output $laptop_output transform normal; mode "default"
        bindsym Return exec --no-startup-id ~/.dotfiles/scripts/.scripts/sway_tablet_autorotate stop; output $laptop_output transform normal; mode "default"
}

bindsym $mod+r mode "resize"
bindsym $mod+Shift+t exec --no-startup-id ~/.dotfiles/scripts/.scripts/sway_tablet_autorotate start $laptop_output; mode "tablet"
bindsym $mod+t exec kitty

default_border pixel 3
