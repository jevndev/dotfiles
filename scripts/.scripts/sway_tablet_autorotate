#!/usr/bin/env bash
set -euo pipefail

PIDFILE="${XDG_RUNTIME_DIR:-/tmp}/sway-tablet-autorotate.pid"
OUTPUT="${2:-eDP-1}"
CMD="${1:-start}"

start() {
    if [[ -f "$PIDFILE" ]]; then
        local existing_pid
        existing_pid="$(cat "$PIDFILE")"
        if [[ -n "$existing_pid" ]] && kill -0 "$existing_pid" 2>/dev/null; then
            exit 0
        fi
    fi

    if ! command -v monitor-sensor >/dev/null 2>&1; then
        notify-send "Tablet autorotate" "monitor-sensor is not installed" || true
        exit 1
    fi

    echo "$$" > "$PIDFILE"
    trap 'rm -f "$PIDFILE"' EXIT INT TERM

    monitor-sensor --accel | while IFS= read -r line; do
        case "$line" in
            *"orientation changed:"*)
                orientation="${line##*: }"
                transform=""
                case "$orientation" in
                    normal)
                        transform="normal"
                        ;;
                    bottom-up)
                        transform="180"
                        ;;
                    right-up)
                        transform="90"
                        ;;
                    left-up)
                        transform="270"
                        ;;
                    *)
                        continue
                        ;;
                esac

                swaymsg output "$OUTPUT" transform "$transform" >/dev/null
                ;;
        esac
    done
}

stop() {
    if [[ -f "$PIDFILE" ]]; then
        local pid
        pid="$(cat "$PIDFILE")"
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
        fi
        rm -f "$PIDFILE"
    fi
}

case "$CMD" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    *)
        echo "Usage: $0 [start|stop] [output]" >&2
        exit 1
        ;;
esac
